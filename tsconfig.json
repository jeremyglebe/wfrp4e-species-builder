{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": [
      // not needed for all type referencing
      // but does ensure Foundry's global objects are recognized by the editor
      "fvtt-types"
    ],
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true
  },
  "include": [
    // Typescript files
    "src/**/*.ts",
    // Vue Single File Components
    "src/**/*.vue",
    // Vite configuration for building
    "vite.config.ts"
  ]
}
