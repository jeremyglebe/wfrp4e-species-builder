{
  "name": "wfrp4e-species-builder",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "release": "node ./scripts/create-release.mjs",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "filetree": "node ./scripts/generate-tree.mjs --root-label \"Foundry WFRP4e Species Builder\" --untracked --output ./tree"
  },
  "dependencies": {
    "@upscalerjs/esrgan-thick": "^1.0.0-beta.16",
    "upscaler": "^1.0.0-beta.19",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
